# Expert Mind Skill — example environment file.
# Copy to .env and fill in only the providers you actually use.

# === REQUIRED: LLM provider (pick one) ===
# ANTHROPIC_API_KEY=sk-ant-api03-...
# OPENAI_API_KEY=sk-...
# OLLAMA_BASE_URL=http://localhost:11434

# === OPTIONAL: Source credentials ===
# Apify — for linkedin_apify and x_apify adapters
# APIFY_TOKEN=apify_api_...

# X/Twitter official API — only if you pay for Basic tier ($100/mo) or higher.
# Free tier blocks reading other users' tweets, so for most users x_apify is far cheaper.
# X_BEARER_TOKEN=...

# Readwise — for readwise_reader adapter
# READWISE_TOKEN=...

# Telegram — NOT NEEDED for telegram_public (we use t.me/s/ HTML, no auth).
# Only set these if you build a Telethon-based adapter for private channels.
# TELEGRAM_API_ID=...
# TELEGRAM_API_HASH=...

# YouTube — NOT NEEDED. Adapter uses channel RSS (no key) + transcript scraping.
# Set only if you extend the adapter to use Data API v3 for richer metadata.
# YOUTUBE_API_KEY=...

# IMAP — for email_forward adapter
# IMAP_HOST=imap.gmail.com
# IMAP_USER=you@example.com
# IMAP_PASS=app-password

# === OPTIONAL: Pipeline tuning ===
# EXPERT_MIND_JUDGE_MODEL=claude-sonnet-4-5
# EXPERT_MIND_LINKEDIN_MAX_POSTS=100
