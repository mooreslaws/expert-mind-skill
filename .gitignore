# Secrets — never commit
.env
.env.*
!.env.example

# User-generated personas (each user keeps their own)
personas/*.yaml
!personas/.gitkeep

# Pipeline workspace (transient, gitignored)
staging/
output/_evaluation.json
output/_*.log

# Logs (user-specific)
logs/

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.ruff_cache/

# IDE
.vscode/
.idea/
.cursor/

# OS
.DS_Store
Thumbs.db
